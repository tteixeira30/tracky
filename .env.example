# Copia este ficheiro para ".env" e preenche os valores. NÃO partilhes o .env.
# (o .env está no .gitignore e nunca deve ir para o repositório)

# Domínio público onde a app vai correr (ex: o-meu-tracky.duckdns.org)
DOMAIN=

# Palavra-passe da base de dados — inventa uma longa e aleatória
DB_PASSWORD=

# Segredo para assinar as sessões (JWT). Gera um com:
#   openssl rand -base64 48
JWT_SECRET=

# Código de convite exigido para criar conta. Deixa vazio para registo aberto.
# Partilha este código só com as pessoas que queres que usem a app.
INVITE_CODE=

# (Opcional) Origens CORS permitidas, separadas por vírgulas — usado pela app
# mobile. Vazio = default permissivo. Para restringir, usa o teu domínio +
# as origens do Capacitor:
#   https://<o-teu-dominio>,http://localhost,https://localhost,capacitor://localhost
TRACKY_CORS_ORIGINS=
